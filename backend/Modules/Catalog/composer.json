{
    "name": "nwidart/catalog",
    "description": "",
    "authors": [
        {
            "name": "Nicolas Widart",
            "email": "n.widart@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Catalog\\": "app/",
            "Modules\\Catalog\\Database\\Factories\\": "database/factories/",
            "Modules\\Catalog\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Catalog\\Tests\\": "tests/"
        }
    }
}
