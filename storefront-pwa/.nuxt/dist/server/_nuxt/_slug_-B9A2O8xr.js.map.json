A;AAAA,UAAa,UAAQ,CAAA,MAAK,KAAA,QAAO;AAAA,QAAA;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_ssrInterpolate","_ssrRenderList","_ssrRenderComponent"],"sources":["../../../../components/product/ProductCatalogSidebar.vue","../../../../pages/category/[slug].vue"],"sourcesContent":["<template>\n  <div class=\"space-y-5\">\n    <button v-if=\"hasActive\" @click=\"emit('update', 'reset', true)\"\n      class=\"text-sm text-indigo-600 hover:underline\">Xóa bộ lọc</button>\n\n    <!-- Giá -->\n    <div class=\"border-b pb-4\">\n      <h3 class=\"font-semibold mb-3\">Giá</h3>\n      <div class=\"flex gap-2\">\n        <input v-model.number=\"priceMin\" type=\"number\" placeholder=\"Từ\" class=\"w-1/2 border rounded px-2 py-1 text-sm\" />\n        <input v-model.number=\"priceMax\" type=\"number\" placeholder=\"Đến\" class=\"w-1/2 border rounded px-2 py-1 text-sm\" />\n      </div>\n      <button @click=\"emit('update', 'price', `${priceMin}-${priceMax}`)\"\n        class=\"mt-2 w-full bg-indigo-600 text-white text-sm py-1.5 rounded hover:bg-indigo-700\">Áp dụng</button>\n    </div>\n\n    <!-- Thương hiệu -->\n    <div v-if=\"filters?.brands?.length\" class=\"border-b pb-4\">\n      <h3 class=\"font-semibold mb-3\">Thương hiệu</h3>\n      <div class=\"space-y-1.5 max-h-40 overflow-y-auto\">\n        <label v-for=\"b in filters.brands\" :key=\"b.id\" class=\"flex items-center gap-2 cursor-pointer text-sm\">\n          <input type=\"checkbox\" :value=\"b.id\" v-model=\"selectedBrands\" @change=\"emit('update', 'brand', selectedBrands.join(','))\" class=\"accent-indigo-600\" />\n          {{ b.name }}\n        </label>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst emit = defineEmits<{ update: [key: string, value: any] }>()\ndefineProps<{ selected: Record<string, any> }>()\n\nconst priceMin = ref(0)\nconst priceMax = ref(50000000)\nconst selectedBrands = ref<number[]>([])\n\nconst { data: filters } = await useAsyncData('sidebar-filters', () => useProductApi().getFilters())\nconst hasActive = computed(() => selectedBrands.value.length > 0)\n</script>\n","<template>\n  <div class=\"max-w-7xl mx-auto px-4 py-8\">\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-8\">\n      <aside class=\"md:col-span-1\">\n        <ProductCatalogSidebar :selected=\"selectedFilters\" @update=\"updateFilter\" />\n      </aside>\n      <main class=\"md:col-span-3\">\n        <div class=\"flex justify-between items-center mb-6\">\n          <p class=\"text-gray-500 text-sm\">{{ products?.total ?? 0 }} sản phẩm</p>\n          <select v-model=\"sort\" class=\"border rounded px-3 py-1.5 text-sm\">\n            <option value=\"newest\">Mới nhất</option>\n            <option value=\"price-asc\">Giá tăng dần</option>\n            <option value=\"price-desc\">Giá giảm dần</option>\n          </select>\n        </div>\n        <div v-if=\"pending\" class=\"grid grid-cols-2 md:grid-cols-3 gap-6\">\n          <UiSkeletonCard v-for=\"i in 9\" :key=\"i\" />\n        </div>\n        <div v-else class=\"grid grid-cols-2 md:grid-cols-3 gap-6\">\n          <ProductCard v-for=\"p in products?.data\" :key=\"p.id\" :product=\"p\" />\n        </div>\n        <UiPagination v-if=\"totalPages > 1\" :current=\"page\" :total=\"totalPages\" @change=\"p => page = p\" />\n      </main>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst route  = useRoute()\nconst sort   = ref((route.query.sort as string) || 'newest')\nconst page   = ref(Number(route.query.page) || 1)\nconst selectedFilters = ref<Record<string, any>>({})\n\nconst { data: products, pending, refresh } = await useAsyncData(\n  `category-${route.params.slug}`,\n  () => useProductApi().getByCategory(route.params.slug as string, {\n    sort: sort.value, page: page.value, ...selectedFilters.value,\n  })\n)\n\nconst totalPages = computed(() => Math.ceil((products.value?.total ?? 0) / 12))\n\nconst updateFilter = (key: string, value: any) => {\n  if (key === 'reset') { selectedFilters.value = {} } else { selectedFilters.value[key] = value }\n  page.value = 1\n  refresh()\n}\n\nwatch([sort, page], refresh)\n</script>\n"],"version":3}