,cAAc,CAAC,MAAc,IAAI,KAAK,aAAa,SAAS,EAAE,OAAO,YAAY,UAAU,MAAA,CAAO,EAAE,OAAO,CAAC;AAMlH,eAAW;AAAA,MACT,OAAO,MAAM,QAAQ,OAAO,QAAQ;AAAA,MACpC,aAAa,MAAM,QAAQ,OAAO,eAAe;AAAA,MACjD,SAAS,MAAM,QAAQ,OAAO,QAAQ;AAAA,MACtC,eAAe,MAAM,QAAQ,OAAO,eAAe;AAAA,MACnD,SAAS,MAAM,QAAQ,OAAO,gBAAgB,CAAC,GAAG,aAAa;AAAA,IAAA,CAChE;AAED,YAAQ;AAAA,MACN,QAAQ,CAAC;AAAA,QACP,MAAM;AAAA,QACN,UAAU,SAAS,MAAM,KAAK,UAAU;AAAA,UACtC,YAAY;AAAA,UACZ,SAAS;AAAA,UACT,MAAM,QAAQ,OAAO;AAAA,UACrB,aAAa,QAAQ,OAAO;AAAA,UAC5B,KAAK,QAAQ,OAAO;AAAA,UACpB,OAAO,QAAQ,OAAO,eAAe,IAAI,CAAA,MAAK,EAAE,SAAS;AAAA,UACzD,QAAQ;AAAA,YACN,SAAS;AAAA,YACT,OAAO,QAAQ,OAAO;AAAA,YACtB,eAAe;AAAA,YACf,eAAe,QAAQ,OAAO,mBAAmB,KAAK,IAClD,+BACA;AAAA,UAAA;AAAA,QACN,CACD,CAAC;AAAA,MAAA,CACH;AAAA,IAAA,CACF;;;;;;;;UAhGYJ,MAAA,OAAA,GAAO;AAAE,cAAA,OAAAH,eAAAC,WAAA,EAAA,OAAM,iCAA6B,MAAA,CAAA,CAAA,uDAAA;;UAElC,QAAQE,MAAA,OAAA,EAAQ,iBAAa,CAAA;AAAA,QAAA;4EAGRE,eAAAF,MAAA,OAAA,EAAQ,IAAI,oDACAE,eAAAF,MAAA,OAAA,EAAQ,GAAG,wEAEb,YAAYA,MAAA,OAAA,EAAQ,KAAK,CAAA;YACzCA,MAAA,OAAA,EAAQ,iBAAiB,QAAM;;YAAG,SAASA,MAAA,OAAA;AAAA,YAAU,UAAQ,CAAA,MAAK,gBAAA,QAAkB;AAAA,UAAA;;;;;UAC1F,OAAOA,MAAA,eAAA,GAAiB,SAASA,MAAA,OAAA,EAAQ,mBAAe;AAAA,QAAA;0NAKrDA,MAAA,GAAA,CAAG,oKAKUK,sBAAAL,MAAA,SAAA,EAAU,WAAO,CAAKA,MAAA,OAAA,EAAQ,eAAe,IAAA,cAAA,oHAE7EE,eAAA,CAAAF,MAAA,OAAA,EAAQ,kBAAe,aAAA,cAAA;AAGpB,YAAAA,MAAA,OAAA,EAAQ,eAAa;AAEM,gBAAA,wGAAAE,eAAAF,MAAA,OAAA,EAAQ,WAAW,CAAA,YAAA;AAAA;;;;sBAOhCA,MAAA,OAAA,GAAS,MAAI,CAAlB,MAAC;;YAAoB,KAAK,EAAE;AAAA,YAAK,SAAS;AAAA,UAAA;;;;UAM5C,cAAY,OAAOA,aAAM,OAAO,EAAE;AAAA,UAAI,KAAKA,MAAA,SAAA;AAAA,QAAA;;UAC3C,cAAY,OAAOA,aAAM,OAAO,EAAE;AAAA,UAAI,yBAAW,UAAA;AAAA,QAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderAttr","_unref","_ssrRenderList","_ssrInterpolate","_ssrRenderClass","_withAsyncContext","_ssrIncludeBooleanAttr"],"sources":["../../../../components/product/ProductGallery.vue","../../../../components/product/ProductVariantSelector.vue","../../../../components/product/ProductStockIndicator.vue","../../../../components/product/ReviewList.vue","../../../../components/product/ReviewForm.vue","../../../../pages/products/[id].vue"],"sourcesContent":["<template>\n  <div class=\"space-y-3\">\n    <div class=\"aspect-square bg-gray-100 rounded-xl overflow-hidden\">\n      <img :src=\"main\" alt=\"Product\" class=\"w-full h-full object-cover cursor-zoom-in\" @click=\"zoom = true\" />\n    </div>\n    <div class=\"grid grid-cols-4 gap-2\">\n      <img v-for=\"(img, i) in images\" :key=\"i\" :src=\"img.image_url\"\n        class=\"aspect-square object-cover rounded cursor-pointer border-2 transition\"\n        :class=\"main === img.image_url ? 'border-indigo-500' : 'border-transparent'\"\n        @click=\"main = img.image_url\" />\n    </div>\n    <div v-if=\"zoom\" class=\"fixed inset-0 bg-black/80 z-50 flex items-center justify-center\" @click=\"zoom = false\">\n      <img :src=\"main\" class=\"max-h-screen max-w-screen-md object-contain\" />\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { ProductImage } from '~/types/models.types'\nconst props = defineProps<{ images: ProductImage[] }>()\nconst main = ref(props.images[0]?.image_url ?? '/placeholder.png')\nconst zoom = ref(false)\n</script>\n","<template>\n  <div class=\"space-y-4\">\n    <div v-for=\"attr in attrs\" :key=\"attr.name\">\n      <p class=\"text-sm font-semibold mb-2 capitalize\">{{ attr.name }}</p>\n      <div class=\"flex flex-wrap gap-2\">\n        <button v-for=\"val in attr.values\" :key=\"val\" @click=\"select(attr.name, val)\"\n          class=\"px-3 py-1.5 text-sm border rounded-lg transition\"\n          :class=\"selected[attr.name] === val ? 'border-indigo-600 bg-indigo-50 text-indigo-700' : 'border-gray-300 hover:border-gray-400'\">\n          {{ val }}\n        </button>\n      </div>\n    </div>\n    <div v-if=\"matched\" class=\"bg-indigo-50 rounded-lg p-3 text-sm\">\n      Biến thể: <strong>{{ matched.variant_name }}</strong>\n      <span v-if=\"matched.price_override\" class=\"ml-2 text-red-600 font-bold\">\n        {{ new Intl.NumberFormat('vi-VN',{style:'currency',currency:'VND'}).format(matched.price_override) }}\n      </span>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { Product, ProductVariant } from '~/types/models.types'\nconst props = defineProps<{ product: Product }>()\nconst emit  = defineEmits<{ select: [v: ProductVariant] }>()\nconst selected = ref<Record<string, string>>({})\n\nconst attrs = computed(() => {\n  const map: Record<string, Set<string>> = {}\n  props.product.productVariants?.forEach(v =>\n    Object.entries(v.attributes ?? {}).forEach(([k, val]) => {\n      if (!map[k]) map[k] = new Set()\n      map[k].add(val)\n    })\n  )\n  return Object.entries(map).map(([name, values]) => ({ name, values: [...values] }))\n})\n\nconst matched = computed(() =>\n  props.product.productVariants?.find(v =>\n    Object.entries(selected.value).every(([k, val]) => v.attributes?.[k] === val)\n  ) ?? null\n)\n\nconst select = (name: string, val: string) => {\n  selected.value[name] = val\n  if (matched.value) emit('select', matched.value)\n}\n</script>\n","<template>\n  <div v-if=\"stock > 0\" class=\"flex items-center gap-2\">\n    <span class=\"text-sm\" :class=\"stock > 10 ? 'text-green-600' : 'text-orange-500'\">\n      {{ stock > 10 ? 'Còn hàng' : `Còn ${stock} sản phẩm` }}\n    </span>\n    <div class=\"w-24 h-1.5 bg-gray-200 rounded-full overflow-hidden\">\n      <div class=\"h-full rounded-full transition-all\" :class=\"stock > 10 ? 'bg-green-500' : 'bg-orange-400'\"\n        :style=\"{ width: `${Math.min(100, (stock / 20) * 100)}%` }\" />\n    </div>\n  </div>\n  <p v-else class=\"text-red-600 font-semibold text-sm\">Hết hàng</p>\n</template>\n\n<script setup lang=\"ts\">\ndefineProps<{ stock: number }>()\n</script>\n","<template>\n  <div class=\"space-y-5\">\n    <div class=\"flex items-center justify-between\">\n      <h3 class=\"font-semibold\">Đánh giá từ khách hàng</h3>\n      <select v-model=\"sort\" class=\"border rounded px-2 py-1 text-sm\">\n        <option value=\"newest\">Mới nhất</option>\n        <option value=\"highest\">Cao nhất</option>\n        <option value=\"lowest\">Thấp nhất</option>\n      </select>\n    </div>\n\n    <div v-if=\"pending\" class=\"space-y-3\">\n      <div v-for=\"i in 3\" :key=\"i\" class=\"h-24 bg-gray-100 rounded-lg animate-pulse\" />\n    </div>\n\n    <UiEmptyState v-else-if=\"!reviews?.length\" icon=\"💬\" title=\"Chưa có đánh giá\" message=\"Hãy là người đầu tiên đánh giá sản phẩm này\" />\n\n    <div v-else class=\"space-y-4\">\n      <div v-for=\"r in reviews\" :key=\"r.id\" class=\"border rounded-xl p-4\">\n        <div class=\"flex justify-between items-start mb-2\">\n          <div>\n            <p class=\"font-semibold text-sm\">{{ r.user?.name ?? 'Khách hàng' }}</p>\n            <p class=\"text-xs text-gray-400\">{{ new Date(r.created_at).toLocaleDateString('vi-VN') }}</p>\n          </div>\n          <span class=\"text-sm\">{{ '⭐'.repeat(r.rating) }}</span>\n        </div>\n        <p class=\"text-sm text-gray-700\">{{ r.content }}</p>\n      </div>\n    </div>\n\n    <UiPagination v-if=\"totalPages > 1\" :current=\"page\" :total=\"totalPages\" @change=\"p => page = p\" />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst props = defineProps<{ productId: number }>()\nconst sort  = ref('newest')\nconst page  = ref(1)\n\nconst { data: result, pending, refresh } = await useAsyncData(\n  `reviews-${props.productId}`,\n  () => useApi()(`crm/v1/reviews?product_id=${props.productId}&page=${page.value}&sort=${sort.value}`)\n)\n\nconst reviews    = computed(() => (result.value as any)?.data ?? [])\nconst totalPages = computed(() => Math.ceil(((result.value as any)?.total ?? 0) / 5))\n\nwatch([sort, page], refresh)\n</script>\n","<template>\n  <form @submit.prevent=\"submit\" class=\"bg-gray-50 rounded-xl p-5 space-y-4\">\n    <h3 class=\"font-semibold\">Viết đánh giá</h3>\n    <div>\n      <p class=\"text-sm font-medium mb-2\">Đánh giá</p>\n      <div class=\"flex gap-1\">\n        <button v-for=\"s in 5\" :key=\"s\" type=\"button\" @click=\"rating = s\" class=\"text-2xl transition\">\n          {{ s <= rating ? '⭐' : '☆' }}\n        </button>\n      </div>\n    </div>\n    <textarea v-model=\"text\" rows=\"4\" maxlength=\"500\" placeholder=\"Chia sẻ trải nghiệm của bạn...\"\n      class=\"w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-400 focus:outline-none resize-none\" />\n    <p class=\"text-xs text-gray-400 -mt-2\">{{ text.length }}/500</p>\n    <p v-if=\"error\" class=\"text-red-600 text-sm\">{{ error }}</p>\n    <button type=\"submit\" :disabled=\"!rating || !text || loading\"\n      class=\"w-full bg-indigo-600 text-white py-2.5 rounded-lg font-semibold hover:bg-indigo-700 disabled:opacity-50\">\n      {{ loading ? 'Đang gửi...' : 'Gửi đánh giá' }}\n    </button>\n  </form>\n</template>\n\n<script setup lang=\"ts\">\nconst props = defineProps<{ productId: number }>()\nconst emit  = defineEmits<{ submitted: [] }>()\nconst rating  = ref(0)\nconst text    = ref('')\nconst loading = ref(false)\nconst error   = ref('')\n\nconst submit = async () => {\n  if (!rating.value || !text.value) return\n  loading.value = true\n  error.value   = ''\n  try {\n    await useApi()('crm/v1/reviews', { method: 'POST', body: { product_id: props.productId, rating: rating.value, content: text.value } })\n    rating.value = 0\n    text.value   = ''\n    emit('submitted')\n    useUiStore().addToast('Đánh giá đã được gửi!', 'success')\n  } catch {\n    error.value = 'Có lỗi xảy ra. Vui lòng thử lại.'\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n","<template>\n  <div v-if=\"product\" class=\"max-w-7xl mx-auto px-4 py-8\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\">\n      <ProductGallery :images=\"product.productImages ?? []\" />\n      <div class=\"space-y-5\">\n        <div>\n          <h1 class=\"text-2xl font-bold\">{{ product.name }}</h1>\n          <p class=\"text-gray-400 text-sm mt-1\">SKU: {{ product.sku }}</p>\n        </div>\n        <p class=\"text-3xl font-bold text-red-600\">{{ formatPrice(product.price) }}</p>\n        <ProductVariantSelector v-if=\"product.productVariants?.length\" :product=\"product\" @select=\"v => selectedVariant = v\" />\n        <ProductStockIndicator :stock=\"selectedVariant?.stock ?? product.available_stock ?? 0\" />\n        <div class=\"flex items-center gap-3\">\n          <span class=\"text-sm font-medium\">Số lượng:</span>\n          <div class=\"flex items-center border rounded-lg\">\n            <button @click=\"qty = Math.max(1, qty - 1)\" class=\"px-3 py-2\">−</button>\n            <input v-model.number=\"qty\" type=\"number\" min=\"1\" class=\"w-12 text-center border-0 py-2 focus:outline-none\" />\n            <button @click=\"qty++\" class=\"px-3 py-2\">+</button>\n          </div>\n        </div>\n        <div class=\"flex gap-3\">\n          <button @click=\"addToCart\" :disabled=\"cartStore.loading || !product.available_stock\"\n            class=\"flex-1 bg-indigo-600 text-white py-3 rounded-lg font-semibold hover:bg-indigo-700 disabled:opacity-50\">\n            {{ !product.available_stock ? 'Hết hàng' : 'Thêm vào giỏ' }}\n          </button>\n        </div>\n        <div v-if=\"product.productImages\" class=\"border-t pt-5\">\n          <h3 class=\"font-semibold mb-2\">Mô tả</h3>\n          <p class=\"text-gray-600 text-sm\">{{ product.description }}</p>\n        </div>\n      </div>\n    </div>\n    <div class=\"mt-16\">\n      <h2 class=\"text-xl font-bold mb-6\">Sản phẩm liên quan</h2>\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\">\n        <ProductCard v-for=\"r in related?.data\" :key=\"r.id\" :product=\"r\" />\n      </div>\n    </div>\n\n    <!-- Reviews -->\n    <div class=\"mt-16 border-t pt-10 space-y-8\">\n      <ProductReviewList :product-id=\"Number(route.params.id)\" :key=\"reviewKey\" />\n      <ProductReviewForm :product-id=\"Number(route.params.id)\" @submitted=\"reviewKey++\" />\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport type { ProductVariant } from '~/types/models.types'\n\nconst route      = useRoute()\nconst cartStore  = useCartStore()\nconst qty        = ref(1)\nconst reviewKey  = ref(0)\nconst selectedVariant = ref<ProductVariant | null>(null)\n\nconst { data: product } = await useAsyncData(`product-${route.params.id}`,\n  () => useProductApi().getById(route.params.id as string)\n)\nconst { data: related } = await useAsyncData(`related-${route.params.id}`,\n  () => useProductApi().getRelated(route.params.id as string)\n)\n\nconst formatPrice = (p: number) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(p)\n\nconst addToCart = () => cartStore.addToCart(\n  product.value!.id, qty.value, selectedVariant.value?.id\n)\n\nuseSeoMeta({\n  title: () => product.value?.name ?? '',\n  description: () => product.value?.description ?? '',\n  ogTitle: () => product.value?.name ?? '',\n  ogDescription: () => product.value?.description ?? '',\n  ogImage: () => product.value?.productImages?.[0]?.image_url ?? '',\n})\n\nuseHead({\n  script: [{\n    type: 'application/ld+json',\n    children: computed(() => JSON.stringify({\n      '@context': 'https://schema.org/',\n      '@type': 'Product',\n      name: product.value?.name,\n      description: product.value?.description,\n      sku: product.value?.sku,\n      image: product.value?.productImages?.map(i => i.image_url),\n      offers: {\n        '@type': 'Offer',\n        price: product.value?.price,\n        priceCurrency: 'VND',\n        availability: (product.value?.available_stock ?? 0) > 0\n          ? 'https://schema.org/InStock'\n          : 'https://schema.org/OutOfStock',\n      },\n    })),\n  }],\n})\n</script>\n"],"version":3}